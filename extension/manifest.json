{
    "manifest_version": 3,
    "name": "Upwork Profile Optimizer",
    "version": "1.0.0",
    "description": "AI-powered Upwork profile optimizer. Score, rewrite & optimize your profile with Claude AI.",
    "permissions": [
        "activeTab",
        "storage",
        "scripting"
    ],
    "host_permissions": [
        "https://www.upwork.com/*",
        "https://api.anthropic.com/*"
    ],
    "action": {
        "default_popup": "popup.html",
        "default_icon": {
            "16": "icons/icon.png"
        }
    },
    "content_scripts": [
        {
            "matches": [
                "https://www.upwork.com/freelancers/*",
                "https://www.upwork.com/profile/*",
                "https://www.upwork.com/o/profiles/*"
            ],
            "css": [
                "panel.css"
            ],
            "js": [
                "contentPrompts.js",
                "content.js"
            ],
            "run_at": "document_idle"
        }
    ],
    "background": {
        "service_worker": "background.js"
    },
    "icons": {
        "16": "icons/icon.png"
    }
}